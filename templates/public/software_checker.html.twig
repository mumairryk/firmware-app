<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Software Version Checker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vuetify@3/dist/vuetify.min.css">
    <style>
        body { font-family: 'Rubik', sans-serif; padding: 20px; }
        .download-link { color: #389e0d; }
        .v-alert { padding: 10px; margin-top: 10px; border-radius: 5px; }
    </style>
</head>
<body>
<div id="app" class="container">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="card-title mb-3 text-center">Software Version Checker</h3>
            <p class="text-center text-muted">Check if an update is available for your CarPlay / Android Auto MMI</p>
            <h3>Software Version Checker <a href="/admin" class="btn btn-secondary btn-sm float-end">Admin Dashboard</a></h3>
            <div class="mb-3">
                <label class="form-label">Software Version *</label>
                <input type="text" v-model="version" class="form-control" placeholder="Enter your software version">
            </div>

            <div class="mb-3">
                <label class="form-label">MCU Version (Optional)</label>
                <input type="text" v-model="mcuVersion" class="form-control" placeholder="Not Required">
            </div>

            <div class="mb-3">
                <label class="form-label">HW Version *</label>
                <input type="text" v-model="hwVersion" class="form-control" placeholder="Enter your HW version">
            </div>

            <button @click="checkSoftware" class="btn btn-primary w-100 mb-3">Check</button>

            <!-- Result -->
            <p id="msg"></p>
            <div v-if="msg" :class="{'alert alert-success': versionExist, 'alert alert-danger': !versionExist}">
                <div class="mt-2">
                    <a v-if="st" :href="st" target="_blank" class="btn btn-success btn-sm">Download ST Version</a>
                    <a v-if="gd" :href="gd" target="_blank" class="btn btn-info btn-sm">Download GD Version</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const { createApp } = Vue;

    createApp({
        data() {
            return {
                version: '',
                mcuVersion: '',
                hwVersion: '',
                versionExist: false,
                msg: '',
                st: '',
                gd: ''
            };
        },
        methods: {
            async checkSoftware() {
                this.versionExist = false;
                this.msg = '';
                this.st = '';
                this.gd = '';
                let msgElement = document.getElementById('msg');

                try {
                    const response = await axios.get('/api/carplay/software/version', {
                        params: {
                            version: this.version,
                            mcuVersion: this.mcuVersion,
                            hwVersion: this.hwVersion
                        }
                    });

                    if (response.status === 200 && response.data) {
                        this.versionExist = response.data.versionExist || false;
                        this.st = response.data.st || '';
                        this.gd = response.data.gd || '';
                        this.msg = response.data.msg || 'No message received';
                        msgElement.textContent = response.data.msg || 'No message received';
                    } else {
                        this.msg = 'Something went wrong. Please try again.';
                        msgElement.textContent = 'Something went wrong. Please try again.';
                    }
                } catch (err) {
                    console.error(err);
                    this.msg = 'Failed to fetch software details. Please try again.';
                    msgElement.textContent = 'Failed to fetch software details. Please try again.';
                }
            }
        }
    }).mount('#app');
</script>
</body>
</html>
